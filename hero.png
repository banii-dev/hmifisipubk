ll"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼk ͼy"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span class="ͼt">document</span><span class="ͼn">.</span><span>querySelectorAll(</span><span class="ͼr">"nav a"</span><span>)</span><span class="ͼn">.</span><span>forEach(</span><span class="ͼt">link</span><span> =&gt; {</span><br><br><span class="ͼt">link</span><span class="ͼn">.</span><span>addEventListener(</span><span class="ͼr">"click"</span><span>, </span><span class="ͼn">function</span><span>(</span><span class="ͼt">e</span><span>){</span><br><br><span class="ͼt">e</span><span class="ͼn">.</span><span>preventDefault()</span><br><br><span class="ͼn">const</span><span> </span><span class="ͼt">target</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">document</span><span class="ͼn">.</span><span>querySelector(</span><span class="ͼq">this</span><span class="ͼn">.</span><span>getAttribute(</span><span class="ͼr">"href"</span><span>))</span><br><br><span class="ͼt">target</span><span class="ͼn">.</span><span>scrollIntoView({</span><br><span>behavior:</span><span class="ͼr">"smooth"</span><br><span>})</span><br><br><span>})</span><br><br><span>})</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
