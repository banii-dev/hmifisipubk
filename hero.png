<hr data-start="146" data-end="149">
<h1 data-section-id="1rmiwok" data-start="151" data-end="176">1️⃣ Buat Folder Website</h1>
<p data-start="177" data-end="204">Di komputer kamu (Windows):</p>
<ol data-start="206" data-end="302">
<li data-section-id="cvp8sr" data-start="206" data-end="234">
<p data-start="209" data-end="234">Klik <strong data-start="214" data-end="234">kanan di Desktop</strong></p>
</li>
<li data-section-id="ijihx6" data-start="235" data-end="258">
<p data-start="238" data-end="258">Pilih <strong data-start="244" data-end="258">New / Baru</strong></p>
</li>
<li data-section-id="159wzne" data-start="259" data-end="278">
<p data-start="262" data-end="278">Pilih <strong data-start="268" data-end="278">Folder</strong></p>
</li>
