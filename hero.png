br><span>background:#004225;</span><br><span>color:white;</span><br><span>padding:60px;</span><br><span>}</span><br><br><span>.hero-content{</span><br><span>display:flex;</span><br><span>align-items:center;</span><br><span>justify-content:space-between;</span><br><span>}</span><br><br><span>.hero img{</span><br><span>width:400px;</span><br><span>border-radius:10px;</span><br><span>}</span><br><br><span>.section{</span><br><span>padding:60px 0;</span><br><span>}</span><br><br><span>.grid{</span><br><span>display:grid;</span><br><span>grid-template-columns:repeat(auto-fit,minmax(220px,1fr));</span><br><span>gap:20px;</span><br><span>}</span><br><br><span>.card{</span><br><span>background:white;</span><br><span>padding:20px;</span><br><span>border-radius:10px;</span><br><span>text-align:center;</span><br><span>box-shadow:0 5px 20px rgba(0,0,0,0.1);</span><br><span>}</span><br><br><span>.card img{</span><br><span>width:100px;</span><br><span>border-radius:50%;</span><br><span>}</span><br><br><span>.program{</span><br><span>list-style:none;</span><br><span>padding:0;</span><br><span>}</span><br><br><span>.program li{</span><br><span>background:white;</span><br><span>margin:10px 0;</span><br><span>padding:15px;</span><br><span>border-radius:8px;</span><br><span>}</span><br><br><span>.galeri{</span><br><span>display:grid;</span><br><span>grid-template-columns:repeat(auto-fit,minmax(150px,1fr));</span><br><span>gap:10px;</span><br><span>}</span><br><br><span>.galeri img{</span><br><span>width:100%;</span><br><span>border-radius:6px;</span><br><span>}</span><br><br><span>.form{</span><br><span>display:flex;</span><br><span>flex-direction:column;</span><br><span>gap:10px;</span><br><span>}</span><br><br><span>.form input,.form textarea{</span><br><span>padding:10px;</span><br><span>}</span><br><br><span>.form button{</span><br><span>background:#005c2e;</span><br><span>color:white;</span><br><span>padding:12px;</span><br><span>border:none;</span><br><span>}</span><br><br><span>footer{</span><br><span>background:#004225;</span><br><span>color:white;</span><br><span>text-align:center;</span><br><span>padding:20px;</span><br><span>}</span><br><br><span>.wa{</span><br><span>position:fixed;</span><br><span>bottom:20px;</span><br><span>right:20px;</span><br><span>background:#25D366;</span><br><span>color:white;</span><br><span>padding:15px;</span><br><span>border-radius:50px;</span><br><span>text-decoration:none;</span><br><span>}</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
