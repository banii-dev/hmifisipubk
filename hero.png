/span><span class="ͼq">10</span><span class="ͼn">px</span><span> </span><span class="ͼn">rgba</span><span>(</span><span class="ͼq">0</span><span>,</span><span class="ͼq">0</span><span>,</span><span class="ͼq">0</span><span>,</span><span class="ͼq">0.1</span><span>);</span><br><span>}</span><br><br><span>.</span><span class="ͼs">program</span><span>{</span><br><span>list-style:</span><span class="ͼq">none</span><span>;</span><br><span>font-size:</span><span class="ͼq">18</span><span class="ͼn">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼs">galeri</span><span>{</span><br><span>display:</span><span class="ͼq">grid</span><span>;</span><br><span>grid-template-columns:</span><span class="ͼn">repeat</span><span>(</span><span class="ͼq">auto-fit</span><span>,</span><span class="ͼn">minmax</span><span>(</span><span class="ͼq">200</span><span class="ͼn">px</span><span>,</span><span class="ͼq">1</span><span class="ͼn">fr</span><span>));</span><br><span>gap:</span><span class="ͼq">10</span><span class="ͼn">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼs">galeri</span><span> </span><span class="ͼv">img</span><span>{</span><br><span>width:</span><span class="ͼq">100</span><span class="ͼn">%</span><span>;</span><br><span>border-radius:</span><span class="ͼq">10</span><span class="ͼn">px</span><span>;</span><br><span>}</span><br><br><span class="ͼv">footer</span><span>{</span><br><span>background:#333;</span><br><span>color:</span><span class="ͼq">white</span><span>;</span><br><span>text-align:</span><span class="ͼq">center</span><span>;</span><br><span>padding:</span><span class="ͼq">20</span><span class="ͼn">px</span><span>;</span><br><span>}</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
