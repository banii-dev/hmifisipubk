-end="888" data-col-size="sm">Rp600</td><td data-col-size="sm"></td></tr><tr data-start="889" data-end="931"><td data-start="889" data-end="903" data-col-size="md">d. Aquadest</td><td data-start="903" data-end="920" data-col-size="sm">2 ml × Rp50/ml</td><td data-start="920" data-end="931" data-col-size="sm">Rp100</td><td data-col-size="sm"></td></tr><tr data-start="932" data-end="979"><td data-start="932" data-end="959" data-col-size="md"><strong data-start="934" data-end="958">Subtotal bahan utama</strong></td><td data-start="959" data-end="961" data-col-size="sm"></td><td data-start="961" data-end="979" data-col-size="sm"><strong data-start="963" data-end="975">Rp26.900</strong></td><td data-col-size="sm"></td></tr><tr data-start="980" data-end="1027"><td data-start="980" data-end="1020" data-col-size="md"><strong data-start="982" data-end="1019">2. Kemasan Primer (Botol &amp; Label)</strong></td><td data-start="1020" data-end="1022" data-col-size="sm"></td><td data-start="1022" data-end="1027" data-col-size="sm"></td><td data-col-size="sm"></td></tr><tr data-start="1028" data-end="1100"><td data-start="1028" data-end="1077" data-col-size="md">a. Botol kaca 30 ml lokal (model polos elegan)</td><td data-start="1077" data-end="1087" data-col-size="sm">Rp5.000</td><td data-start="1087" data-end="1100" data-col-size="sm">Rp5.000</td><td data-col-size="sm"></td></tr><tr data-start="1101" data-end="1148"><td data-start="1101" data-end="1125" data-col-size="md">b. Tutup spray silver</td><td data-start="1125" data-end="1135" data-col-size="sm">Rp1.500</td><td data-start="1135" data-end="1148" data-col-size="sm">Rp1.500</td><td data-col-size="sm"></td></tr><tr data-start="1149" data-end="1209"><td data-start="1149" data-end="1190" data-col-size="md">c. Label stiker glossy (print digital)</td><td data-start="1190" data-end="1198" data-col-size="sm">Rp800</td><td data-start="1198" data-end="1209" data-col-size="sm">Rp800</td><td data-col-size="sm"></td></tr><tr data-start="1210" data-end="1259"><td data-start="1210" data-end="1240" data-col-size="md"><strong data-start="1212" data-end="1239">Subtotal kemasan primer</strong></td><td data-start="1240" data-end="1242" data-col-size="sm"></td><td data-start="1242" data-end="1259" data-col-size="sm"><strong data-start="1244" data-end="1255">Rp7.300</strong></td><td data-col-size="sm"></td></tr><tr data-start="1260" data-end="1299"><td data-start="1260" data-end="1292" data-col-size="md"><strong data-start="1262" data-end="1291">3. Kemasan Sekunder (Box)</strong></td><td data-start="1292" data-end="1294" data-col-size="sm"></td><td data-start="1294" data-end="1299" data-col-size="sm"></td><td data-col-size="sm"></td></tr><tr data-start="1300" data-end="1373"><td data-start="1300" data-end="1350" data-col-size="md">a. Box karton art paper 300 GSM + laminasi doff</td><td data-start="1350" data-end="1360" data-col-size="sm">Rp3.000</td><td data-start="1360" data-end="1373" data-col-size="sm">Rp3.000</td><td data-col-size="sm"></td></tr><tr data-start="1374" data-end="1434"><td data-start="1374" data-end="1415" data-col-size="md">b. Desain cetak standar (tanpa emboss)</td><td data-start="1415" data-end="1423" data-col-size="sm">Rp500</td><td data-start="1423" data-end="1434" data-col-size="sm">Rp500</td><td data-col-size="sm"></td></tr><tr data-start="1435" data-end="1486"><td data-start="1435" data-end="1467" data-col-size="md"><strong data-start="1437" data-end="1466">Subtotal kemasan sekunder</strong></td><td data-start="1467" data-end="1469" data-col-size="sm"></td><td data-start="1469" data-end="1486" data-col-size="sm"><strong data-start="1471" data-end="1482">Rp3.500</strong></td><td data-col-size="sm"></td></tr><tr data-start="1487" data-end="1523"><td data-start="1487" data-end="1516" data-col-size="md"><strong data-start="1489" data-end="1515">4. Produksi &amp; Overhead</strong></td><td data-start="1516" data-end="1518" data-col-size="sm"></td><td data-start="1518" data-end="1523" data-col-size="sm"></td><td data-col-size="sm"></td></tr><tr data-start="1524" data-end="1587"><td data-start="1524" data-end="1564" data-col-size="md">a. Tenaga kerja peracikan &amp; pengisian</td><td data-start="1564" data-end="1574" data-col-size="sm">Rp1.000</td><td data-start="1574" data-end="1587" data-col-size="sm">Rp1.000</td><td data-col-size="sm"></td></tr><tr data-start="1588" data-end="1647"><td data-start="1588" data-end="1628" data-col-size="md">b. Biaya listrik, air, dan alat bantu</td><td data-start="1628" data-end="1636" data-col-size="sm">Rp500</td><td data-start="1636" data-end="1647" data-col-size="sm">Rp500</td><td data-col-size="sm"></td></tr><tr data-start="1648" data-end="1706"><td data-start="1648" data-end="1687" data-col-size="md">c. Penyusutan alat &amp; bahan pendukung</td><td data-start="1687" data-end="1695" data-col-size="sm">Rp500</td><td data-start="1695" data-end="1706" data-col-size="sm">Rp500</td><td data-col-size="sm"></td></tr><tr data-start="1707" data-end="1748"><td data-start="1707" data-end="1731" data-col-size="md"><strong data-start="1709" data-end="1730">Subtotal overhead</strong></td><td data-start="1731" data-end="1733" data-col-size="sm"></td><td data-start="1733" data-end="1748" data-col-size="sm"><strong data-start="1735" data-end="1746">Rp2.000</strong></td><td data-col-size="sm"></td></tr></tbody></table><div class="sticky h-0 select-none end-(--thread-content-margin) self-end"><div class="absolute end-0 flex items-end" style="height: 49px;"><span class="" data-state="closed"><button aria-label="Copy table" class="hover:bg-token-bg-tertiary text-token-text-secondary my-1 rounded-sm p-1 transition-opacity group-[:not(:hover):not(:focus-within)]:pointer-events-none group-[:not(:hover):not(:focus-within)]:opacity-0"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-il7yfj1b.svg#ce3544" fill="currentColor"></use></svg></button></span></div></div></div></div>
<hr data-start="1750" data-end="1753">
<h3 data-section-id="1rdclw7" data-start="1755" data-end="1794">✅ <strong data-start="1761" data-end="1792">Total HPP per botol (30 ml)</strong></h3>
<blockquote data-start="1795" data-end="1850">
<p data-start="1797" data-end="1850"><strong data-start="1797" data-end="1850">Rp26.900 + Rp7.300 + Rp3.500 + Rp2.000 = Rp39.700</strong></p>
</blockquote>
<hr data-start="1852" data-end="1855">
<h3 data-section-id="e84fi7" data-start="1857" data-end="1890">💡 <strong data-start="1864" data-end="1890">Rekomendasi Harga Jual</strong></h3>
<div class="TyagGW_tableContainer"><div tabindex="-1" class="group TyagGW_tableWrapper flex flex-col-reverse w-fit"><table data-start="1891" data-end="2151" class="w-fit min-w-(--thread-content-width)"><thead data-start="1891" data-end="1956"><tr data-start="1891" data-end="1956"><th data-start="1891" data-end="1912" data-col-size="sm" class=""><strong data-start="1893" data-end="1911">Tipe Penjualan</strong></th><th data-start="1912" data-end="1934" data-col-size="sm" class=""><strong data-start="1914" data-end="1933">Harga Jual (Rp)</strong></th><th data-start="1934" data-end="1956" data-col-size="sm" class=""><strong data-start="1936" data-end="1954">Keuntungan (%)</strong></th></tr></thead><tbody data-start="2023" data-end="2151"><tr data-start="2023" data-end="2072"><td data-start="2023" data-end="2055" data-col-size="sm">Retail (langsung ke konsumen)</td><td data-start="2055" data-end="2064" data-col-size="sm">85.000</td><td data-start="2064" data-end="2072" data-col-size="sm">±53%</td></tr><tr data-start="2073" data-end="2112"><td data-start="2073" data-end="2095" data-col-size="sm">Reseller / dropship</td><td data-start="2095" data-end="2104" data-col-size="sm">70.000</td><td data-start="2104" data-end="2112" data-col-size="sm">±43%</td></tr><tr data-start="2113" data-end="2151"><td data-start="2113" data-end="2134" data-col-size="sm">Grosir (≥50 botol)</td><td data-start="2134" data-end="2143" data-col-size="sm">60.000</td><td data-start="2143" data-end="2151" data-col-size="sm">±34%</td></tr></tbody></table><div class="sticky h-0 select-none end-(--thread-content-margin) self-end"><div class="absolute end-0 flex items-end" style="height: 33px;"><span class="" data-state="closed"><button aria-label="Copy table" class="hover:bg-token-bg-tertiary text-token-text-secondary my-1 rounded-sm p-1 transition-opacity group-[:not(:hover):not(:focus-within)]:pointer-events-none group-[:not(:hover):not(:focus-within)]:opacity-0"><svg xmlns="http://www.w3.org/2000/svg" 